# Espectro — configuración de entorno
# La app corre SIN token con el proveedor mock (default). Para activar el LLM real,
# copia este archivo a .env.local, pon LLM_PROVIDER=anthropic y tu key.

# Proveedor de scoring: "mock" (default, corre sin token) | "anthropic"
LLM_PROVIDER=mock

# Solo requerido si LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Modelo a usar cuando el proveedor es anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
