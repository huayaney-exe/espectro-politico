# Espectro — configuración de entorno
# La app corre SIN token con el proveedor mock (default). Para activar el LLM real,
# copia este archivo a .env.local, elige un proveedor y pon tu key.

# Proveedor de scoring: "mock" (default, corre sin token) | "openrouter" | "anthropic" | "openai"
# Recomendado en producción: openrouter (structured outputs + acceso a 300+ modelos).
LLM_PROVIDER=mock

# --- OpenRouter (LLM_PROVIDER=openrouter) — RECOMENDADO ---
# Key en https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo id formato vendor/modelo. Debe soportar structured outputs
# (filtra en https://openrouter.ai/models?supported_parameters=structured_outputs)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Atribución opcional (crea tu página de app en los rankings de OpenRouter)
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Espectro

# --- Anthropic (LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI y compatibles (LLM_PROVIDER=openai) ---
# Funciona con OpenAI, Groq, Together, etc. usando la misma key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Base URL de la API compatible con OpenAI. Deja vacío para OpenAI oficial.
OPENAI_BASE_URL=https://api.openai.com/v1
