# Espectro — configuración de entorno
# La app corre SIN token con el proveedor mock (default). Para activar el LLM real,
# copia este archivo a .env.local, elige un proveedor y pon tu key.

# Proveedor de scoring: "mock" (default, corre sin token) | "anthropic" | "openai"
LLM_PROVIDER=mock

# --- Anthropic (LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI y compatibles (LLM_PROVIDER=openai) ---
# Funciona con OpenAI, OpenRouter, Groq, Together, etc. usando la misma key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Base URL de la API compatible con OpenAI. Deja vacío para OpenAI oficial.
# OpenRouter: https://openrouter.ai/api/v1  |  Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1
